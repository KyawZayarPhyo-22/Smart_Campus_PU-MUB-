@page "/admin/student"
@layout AdminLayout
<!-- 1. STUDENT DATABANK -->
<div class="tab-pane fade show active" id="v-pills-student">

    <div class="mb-4">
        <h3 class="fw-bold mb-1">Student Databank</h3>
    </div>
    <div class="tech-card">
        <!-- RESTORED: Search & Filter -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text search-icon-bg border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Search Student ID or Name...">
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select">
                    <option value="">Filter by Major...</option>
                    <option>Civil Engineering</option>
                    <option>Information Technology</option>
                    <option>Mechanical Engineering</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select">
                    <option value="">Status: All</option>
                    <option>Pending</option>
                    <option>Approved</option>
                </select>
            </div>
            <NavLink href="/admin/student/create" class="nav-link">
                <span class="sidebar-text">Add New Student</span>
            </NavLink>
        </div>

        <div class="table-responsive">
            <table class="table table-tech align-middle mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Roll No</th>
                        <th>Student Name</th>
                        <th>Class Year</th>
                        <th>Major</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr style="color: aliceblue;">

                        <td>1</td>
                        <td>ME-2026-001</td>
                        <td>Mg Mg</td>
                        <td>Third Year</td>
                        <td>Mechanical Engineering</td>
                        <td>
                            <span class="badge bg-success">
                                Active
                            </span>
                        </td>

                        <td>
                            <NavLink href="/admin/student/edit" class="nav-link">
                                <span class="sidebar-text">Edit</span>
                            </NavLink>
                            <button class="btn btn-sm btn-danger" data-bs-toggle="modal"
                                data-bs-target="#deleteStudentModal">
                                <i class="bi bi-trash"></i>
                                Delete
                            </button>
                        </td>

                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
<div class="modal fade" id="deleteStudentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content tech-card">

            <div class="modal-header border-0">
                <h5 class="modal-title text-danger fw-bold">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Confirm Delete
                </h5>

                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body text-center">

                <div class="mb-3">
                    <i class="bi bi-trash-fill" style="font-size:4rem;color:#dc3545;">
                    </i>
                </div>

                <h4 class="fw-bold">
                    Delete Student?
                </h4>

                <p class="text-muted">
                    This action cannot be undone.
                    The tutor information will be permanently removed.
                </p>

            </div>

            <div class="modal-footer border-0 justify-content-center">

                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="button" class="btn btn-danger">
                    <i class="bi bi-trash me-2"></i>
                    Yes, Delete
                </button>

            </div>

        </div>

    </div>
</div>